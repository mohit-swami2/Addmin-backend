PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/aadmin
JWT_EXPIRES_IN=7d
CORS_WHITELIST=http://localhost:5173,http://127.0.0.1:5173
WEB_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Public API base (OAuth callbacks, optional when not using req host)
OAUTH_CALLBACK_BASE_URL=http://localhost:5000

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=admin@aadmin.local

REDIS_URL=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

DEVELOPER_SESSION_SECRET=change-me-developer-session
ERROR_LOG_GROUP_WINDOW_SECONDS=300
DEVELOPER_MODE=false

PROFILE_IMAGE_MAX_SIZE_MB=5
PRODUCT_IMAGE_MAX_SIZE_MB=5

# Amazon S3 (required on Vercel — no persistent disk)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=
AWS_PRESIGN_EXPIRES_SECONDS=3600

# Vercel: paste PEM contents or use \n-escaped single-line keys
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# AAdmin credentials (used by npm run seed:admin)
DEFAULT_ADMIN_EMAIL=aadmin@mailinator.com
DEFAULT_ADMIN_PASSWORD=aadmin@12345
DEFAULT_ADMIN_NAME=AAdmin

# Set to true only for local demo users/products
SEED_SAMPLE_DATA=false
